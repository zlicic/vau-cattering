---
import Layout from '../layouts/Layout.astro';
import MenuCatalog from '../components/MenuCatalog.tsx';
import menuData from '../data/menu.json';

const { categories } = menuData;

const allItems = categories.flatMap(cat =>
  cat.subcategories.flatMap(sub =>
    sub.items.map(item => ({
      ...item,
      categoryId: cat.id,
      categoryName: cat.name,
      subcategoryId: sub.id,
      subcategoryName: sub.name,
    }))
  )
);
---

<Layout title="Ponuda">
  <section class="relative bg-ink text-white py-20 md:py-24 overflow-hidden -mt-[4.5rem] pt-[4.5rem]">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1540189549336-e6e99c3679fe?w=1920&q=80"
        alt="Fresh food"
        class="w-full h-full object-cover opacity-30"
      />
      <div class="absolute inset-0 bg-ink/80" />
    </div>
    <div class="max-w-6xl mx-auto px-4 text-center relative z-10">
      <p class="font-body text-white/60 text-xs uppercase tracking-[0.2em] mb-3">Meni</p>
      <h1 class="font-display text-5xl md:text-6xl mb-3">Naša ponuda</h1>
      <p class="font-body text-white/70 text-lg max-w-xl mx-auto">
        Odaberite jela iz našeg menija i naručite direktno preko WhatsApp-a
      </p>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <MenuCatalog client:load items={allItems} categories={categories} />
  </section>
</Layout>
