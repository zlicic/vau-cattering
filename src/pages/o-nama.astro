---
import Layout from '../layouts/Layout.astro';
import { Award, Users, Heart, ArrowRight } from 'lucide-react';
---

<Layout title="O nama">
  <section class="relative bg-ink text-white py-20 md:py-24 overflow-hidden -mt-[4.5rem] pt-[4.5rem]">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=1920&q=80"
        alt="Kuhinja"
        class="w-full h-full object-cover opacity-25"
      />
      <div class="absolute inset-0 bg-ink/80" />
    </div>
    <div class="max-w-4xl mx-auto px-4 text-center relative z-10">
      <p class="font-body text-white/60 text-xs uppercase tracking-[0.2em] mb-3">Naša priča</p>
      <h1 class="font-display text-5xl md:text-6xl mb-3">O nama</h1>
      <p class="font-body text-white/70 text-lg">
        VAU Ketering — porodična priča o ljubavi prema hrani
      </p>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center mb-20">
        <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-cream">
          <img
            src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=800&q=80"
            alt="VAU Ketering kuhinja"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div>
          <p class="font-body text-ink-light leading-relaxed text-lg mb-6">
            VAU Ketering je nastao iz želje da najbolja domaća jela stignu do vaših stolova — 
            bilo da organizujete rođendan, poslovni ručak, venčanje ili porodičnu proslavu. 
            Sa dugogodišnjim iskustvom u pripremi keteringa, ponosno nudimo jela koja su spremljena 
            sa pažnjom i ljubavlju, koristeći isključivo sveže, lokalne namirnice.
          </p>
          <p class="font-body text-muted leading-relaxed">
            Svaka porudžbina je za nas poseban projekat. Prilagođavamo se vašim potrebama, 
            broju gostiju i tipu događaja. Verujemo da dobra hrana čini svaku proslavu nezaboravnom.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
        <div class="bg-surface rounded-2xl p-8 border border-black/5 hover:shadow-lg transition-shadow text-center">
          <div class="w-14 h-14 mx-auto mb-4 bg-paprika/10 rounded-full flex items-center justify-center">
            <Award size={28} className="text-paprika" strokeWidth={1.5} />
          </div>
          <h3 class="font-display text-xl text-ink mb-2">Kvalitet</h3>
          <p class="font-body text-sm text-ink-light leading-relaxed">
            Isključivo sveže namirnice i tradicionalni recepti bez kompromisa.
          </p>
        </div>
        <div class="bg-surface rounded-2xl p-8 border border-black/5 hover:shadow-lg transition-shadow text-center">
          <div class="w-14 h-14 mx-auto mb-4 bg-gold/10 rounded-full flex items-center justify-center">
            <Users size={28} className="text-gold" strokeWidth={1.5} />
          </div>
          <h3 class="font-display text-xl text-ink mb-2">Iskustvo</h3>
          <p class="font-body text-sm text-ink-light leading-relaxed">
            Stotine uspešnih proslava i zadovoljnih gostiju koji se vraćaju.
          </p>
        </div>
        <div class="bg-surface rounded-2xl p-8 border border-black/5 hover:shadow-lg transition-shadow text-center">
          <div class="w-14 h-14 mx-auto mb-4 bg-sage/10 rounded-full flex items-center justify-center">
            <Heart size={28} className="text-sage" strokeWidth={1.5} />
          </div>
          <h3 class="font-display text-xl text-ink mb-2">Posvećenost</h3>
          <p class="font-body text-sm text-ink-light leading-relaxed">
            Svaka porudžbina je važna. Prilagodjavamo se vašim potrebama i željama.
          </p>
        </div>
      </div>

      <div class="bg-ink rounded-2xl p-10 md:p-12 text-center relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-paprika/15 via-transparent to-transparent" />
        <div class="relative z-10">
          <p class="font-display text-2xl md:text-3xl text-white mb-3">Imate pitanja?</p>
          <p class="font-body text-white/60 mb-8 max-w-lg mx-auto">
            Slobodno nas kontaktirajte — rado ćemo vam pomoći da organizujete savršenu proslavu.
          </p>
          <a
            href={`${import.meta.env.BASE_URL}kontakt`}
            class="inline-flex items-center gap-2 px-8 py-3 bg-paprika text-white font-display text-sm uppercase tracking-widest rounded-xl hover:bg-paprika-dark transition-colors"
          >
            Kontaktiraj nas
            <ArrowRight size={16} />
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
