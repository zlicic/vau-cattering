---
import Layout from '../layouts/Layout.astro';
import CheckoutForm from '../components/CheckoutForm.tsx';
---

<Layout title="Porudžbina">
  <section class="relative bg-ink text-white py-20 md:py-24 overflow-hidden -mt-[4.5rem] pt-[4.5rem]">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1498837167922-ddd27525d352?w=1920&q=80"
        alt="Hrana"
        class="w-full h-full object-cover opacity-25"
      />
      <div class="absolute inset-0 bg-ink/80" />
    </div>
    <div class="max-w-6xl mx-auto px-4 text-center relative z-10">
      <p class="font-body text-white/60 text-xs uppercase tracking-[0.2em] mb-3">Završite kupovinu</p>
      <h1 class="font-display text-5xl md:text-6xl mb-3">Porudžbina</h1>
      <p class="font-body text-white/70 text-lg">Unesite podatke i završite porudžbinu preko WhatsApp-a</p>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <CheckoutForm client:load />
  </section>
</Layout>
