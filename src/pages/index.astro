---
import Layout from '../layouts/Layout.astro';
import menuData from '../data/menu.json';
import { ArrowRight, ChefHat, Truck, Calendar, ChevronDown, Star, Phone } from 'lucide-react';

const featuredItems = menuData.categories.flatMap(c =>
  c.subcategories.flatMap(s => s.items.slice(0, 1).map(i => ({ ...i, categoryName: c.name, subcategoryName: s.name })))
).slice(0, 4);
---

<Layout title="Početna">
  {/* Hero with food image */}
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden -mt-[4.5rem] pt-[4.5rem]">
    {/* Background image */}
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=1920&q=80"
        alt="Delicious catering food spread"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/60" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-black/30" />
    </div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 text-center">
      <p class="animate-fade-up font-body text-white/70 text-xs uppercase tracking-[0.25em] mb-6">
        Ketering za sve prilike
      </p>
      <h1 class="animate-fade-up delay-100 font-display text-6xl md:text-8xl lg:text-9xl text-white mb-6 leading-[0.95] drop-shadow-lg">
        VAU Ketering
      </h1>
      <p class="animate-fade-up delay-200 font-body text-white/80 text-lg md:text-xl max-w-2xl mx-auto mb-12 leading-relaxed">
        Od roštilja za vaše proslave do izbornih torti za porodične trenutke.
        Kvalitetna hrana, dostava na adresu, užitak bez brige.
      </p>
      <div class="animate-fade-up delay-300 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/ponuda"
          class="inline-flex items-center justify-center gap-2 px-10 py-4 bg-paprika text-white font-display text-lg uppercase tracking-widest rounded-xl hover:bg-paprika-dark transition-all duration-300 hover:scale-[1.02] shadow-lg shadow-paprika/25"
        >
          Pogledaj ponudu
          <ArrowRight size={20} strokeWidth={2} />
        </a>
        <a
          href={`https://wa.me/381641234567`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-10 py-4 border border-white/40 text-white font-display text-lg uppercase tracking-widest rounded-xl hover:bg-white hover:text-ink transition-all duration-300"
        >
          <Phone size={18} strokeWidth={2} />
          Naruči odmah
        </a>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-fade-up delay-500">
      <a href="#ponuda" class="flex flex-col items-center gap-2 text-white/50 hover:text-white transition-colors">
        <span class="font-body text-[10px] uppercase tracking-[0.2em]">Saznaj više</span>
        <ChevronDown size={20} className="animate-bounce" />
      </a>
    </div>
  </section>

  {/* Featured Items */}
  <section id="ponuda" class="py-20 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-14">
        <p class="font-body text-paprika text-xs uppercase tracking-[0.2em] mb-3">Izdvajamo iz ponude</p>
        <h2 class="font-display text-4xl md:text-5xl text-ink mb-4">Najpopularnija jela</h2>
        <div class="w-16 h-1 bg-paprika mx-auto rounded-full" />
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {featuredItems.map((item) => (
          <a href="/ponuda" class="group block bg-surface rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-black/5">
            <div class="aspect-[4/3] overflow-hidden bg-cream">
              <img
                src={item.image}
                alt={item.name}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="p-5">
              <p class="font-body text-[10px] text-muted uppercase tracking-widest mb-1">{item.subcategoryName}</p>
              <h3 class="font-display text-lg text-ink mb-1 group-hover:text-paprika transition-colors">{item.name}</h3>
              <p class="font-body text-sm text-paprika font-semibold">{item.price.toLocaleString('sr-RS')} RSD</p>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-12">
        <a
          href="/ponuda"
          class="inline-flex items-center gap-2 px-8 py-3 bg-ink text-white font-display text-sm uppercase tracking-widest rounded-xl hover:bg-ink-light transition-colors"
        >
          Pogledaj celu ponudu
          <ArrowRight size={16} />
        </a>
      </div>
    </div>
  </section>

  {/* Features */}
  <section class="py-20 md:py-24 bg-cream">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-14">
        <p class="font-body text-paprika text-xs uppercase tracking-[0.2em] mb-3">Zašto VAU</p>
        <h2 class="font-display text-4xl md:text-5xl text-ink mb-4">Ono što nas izdvaja</h2>
        <div class="w-16 h-1 bg-paprika mx-auto rounded-full" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-8 bg-white rounded-2xl border border-black/5 hover:shadow-lg transition-all duration-300">
          <div class="w-16 h-16 mx-auto mb-5 bg-paprika/10 rounded-full flex items-center justify-center">
            <ChefHat size={32} className="text-paprika" strokeWidth={1.5} />
          </div>
          <h3 class="font-display text-xl text-ink mb-3">Domaća kuhinja</h3>
          <p class="font-body text-sm text-ink-light leading-relaxed">
            Sva jela pripremaju se po tradicionalnim receptima sa svežim, lokalnim namirnicama.
          </p>
        </div>
        <div class="text-center p-8 bg-white rounded-2xl border border-black/5 hover:shadow-lg transition-all duration-300">
          <div class="w-16 h-16 mx-auto mb-5 bg-gold/10 rounded-full flex items-center justify-center">
            <Truck size={32} className="text-gold" strokeWidth={1.5} />
          </div>
          <h3 class="font-display text-xl text-ink mb-3">Dostava na adresu</h3>
          <p class="font-body text-sm text-ink-light leading-relaxed">
            Brza i pouzdana dostava hrane na vašu lokaciju u dogovorenom terminu.
          </p>
        </div>
        <div class="text-center p-8 bg-white rounded-2xl border border-black/5 hover:shadow-lg transition-all duration-300">
          <div class="w-16 h-16 mx-auto mb-5 bg-sage/10 rounded-full flex items-center justify-center">
            <Calendar size={32} className="text-sage" strokeWidth={1.5} />
          </div>
          <h3 class="font-display text-xl text-ink mb-3">Za svaku priliku</h3>
          <p class="font-body text-sm text-ink-light leading-relaxed">
            Rođendani, venčanja, poslovni ručkovi ili porodične proslave — mi smo tu.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* About teaser */}
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div class="relative">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-cream">
            <img
              src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=800&q=80"
              alt="VAU Ketering priprema hrane"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-paprika/10 rounded-2xl -z-10" />
          <div class="absolute -top-6 -left-6 w-24 h-24 bg-gold/10 rounded-2xl -z-10" />
        </div>
        <div>
          <p class="font-body text-paprika text-xs uppercase tracking-[0.2em] mb-3">O nama</p>
          <h2 class="font-display text-4xl text-ink mb-6">Porodična priča o ljubavi prema hrani</h2>
          <p class="font-body text-ink-light leading-relaxed mb-6 text-lg">
            VAU Ketering je nastao iz želje da najbolja domaća jela stignu do vaših stolova — 
            bilo da organizujete rođendan, poslovni ručak, venčanje ili porodičnu proslavu.
          </p>
          <p class="font-body text-muted leading-relaxed mb-8">
            Sa dugogodišnjim iskustvom u pripremi keteringa, ponosno nudimo jela koja su spremljena 
            sa pažnjom i ljubavlju, koristeći isključivo sveže, lokalne namirnice.
          </p>
          <a
            href="/o-nama"
            class="inline-flex items-center gap-2 px-8 py-3 border-2 border-ink text-ink font-display text-sm uppercase tracking-widest rounded-xl hover:bg-ink hover:text-white transition-all duration-300"
          >
            Saznaj više
            <ArrowRight size={16} />
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Testimonials */}
  <section class="py-20 md:py-24 bg-cream">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-14">
        <p class="font-body text-paprika text-xs uppercase tracking-[0.2em] mb-3">Utisci</p>
        <h2 class="font-display text-4xl md:text-5xl text-ink mb-4">Šta kažu naši klijenti</h2>
        <div class="w-16 h-1 bg-paprika mx-auto rounded-full" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            text: "VAU Ketering je bio savršen izbor za naše venčanje. Hrana je bila izuzetna, a gosti su oduševljeni. Toplo preporučujemo!",
            name: "Ana i Marko",
            event: "Venčanje"
          },
          {
            text: "Svaki put kada imamo poslovni ručak, znamo da je VAU tim pouzdan izbor. Profesionalni, tačni i hrana je uvek fantastična.",
            name: "Jovana P.",
            event: "Poslovni ručak"
          },
          {
            text: "Roštilj za rođendan sina bio je hit! Ćevapi i pljeskavica su bili savršeno pečeni, a dostava je stigla tačno na vreme.",
            name: "Dejan M.",
            event: "Porodična proslava"
          }
        ].map((t) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-black/5 hover:shadow-md transition-shadow">
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <Star size={16} className="text-gold fill-gold" />
              ))}
            </div>
            <p class="font-body text-ink-light leading-relaxed mb-6 text-sm">{t.text}</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-paprika/10 flex items-center justify-center font-display text-paprika text-sm">
                {t.name.charAt(0)}
              </div>
              <div>
                <p class="font-display text-sm text-ink">{t.name}</p>
                <p class="font-body text-xs text-muted">{t.event}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="relative py-20 md:py-28 bg-ink text-white overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-paprika/20 via-transparent to-transparent" />
    <div class="max-w-4xl mx-auto px-4 text-center relative z-10">
      <h2 class="font-display text-4xl md:text-5xl text-white mb-4">Spremni za porudžbinu?</h2>
      <p class="font-body text-white/70 mb-10 max-w-xl mx-auto text-lg leading-relaxed">
        Pogledajte našu ponudu, odaberite jela koja vam se dopadaju i naručite direktno preko WhatsApp-a.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/ponuda"
          class="inline-flex items-center justify-center gap-2 px-10 py-4 bg-paprika text-white font-display text-lg uppercase tracking-widest rounded-xl hover:bg-paprika-dark transition-all duration-300 hover:scale-[1.02]"
        >
          Pogledaj ponudu
          <ArrowRight size={20} />
        </a>
        <a
          href="/kontakt"
          class="inline-flex items-center justify-center gap-2 px-10 py-4 border border-white/30 text-white font-display text-lg uppercase tracking-widest rounded-xl hover:bg-white hover:text-ink transition-all duration-300"
        >
          Kontaktiraj nas
        </a>
      </div>
    </div>
  </section>
</Layout>
